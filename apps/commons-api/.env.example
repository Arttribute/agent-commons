PINATA_JWT=your_pinata_jwt_here
GATEWAY_URL=yourdomain.mypinata.cloud

POSTGRES_DATABASE=""
POSTGRES_USER=""
POSTGRES_PORT=""
POSTGRES_HOST=""
POSTGRES_PASSWORD=""

WALLET_PRIVATE_KEY=""

OPENAI_API_KEY=""

GRAPH_API_KEY=""

SUPABASE_URL=https://your_supabase_url.supabase.co
SUPABASE_KEY=your_supabase_key_here

# Private chat attachment storage. Raw uploads and derived artifacts are stored
# in S3; Postgres stores only object keys, previews, hashes, and metadata.
AGENT_FILES_S3_BUCKET=agent-commons-files
AGENT_FILES_S3_REGION=us-east-1
AGENT_FILES_S3_PREFIX=agent-commons-files
# Production ECS uses the API task role; do not set AWS keys or role ARNs there.
# Optional for Vercel OIDC-style runtimes.
AGENT_FILES_AWS_ROLE_ARN=
# Optional static-key fallback for local development or emergency break-glass only.
AGENT_FILES_AWS_ACCESS_KEY_ID=
AGENT_FILES_AWS_SECRET_ACCESS_KEY=
AGENT_FILES_AWS_SESSION_TOKEN=
# Optional for LocalStack/MinIO development.
AGENT_FILES_S3_ENDPOINT=
AGENT_FILES_S3_FORCE_PATH_STYLE=false

COINBASE_API_KEY_NAME=""
COINBASE_API_KEY_SECRET=""

# Tool Key Encryption (required for OAuth and API key storage)
TOOL_KEY_ENCRYPTION_MASTER="your_32_byte_encryption_key_in_base64"

# OAuth Providers (optional - for Google Workspace, GitHub, etc.)
# Google Workspace OAuth (for Classroom, Drive, Calendar, Gmail)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# GitHub OAuth (for repository access, issues, PRs)
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""

# Slack OAuth (for channels, messages, and workspace updates)
SLACK_OAUTH_CLIENT_ID=""
SLACK_OAUTH_CLIENT_SECRET=""

# Canva OAuth (for Canva Connect APIs)
CANVA_OAUTH_CLIENT_ID=""
CANVA_OAUTH_CLIENT_SECRET=""

# Web app origin used as the default OAuth redirect base for CLI/SDK-initiated
# connect flows (must match the redirect URI registered with the provider),
# e.g. https://app.agentcommons.io
APP_ORIGIN=""
