# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/commons-courses

# App URLs
# NEXT_PUBLIC_BASE_URL is used for checkout success/cancel callbacks.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Resend / Email
# Add RESEND_API_KEY to Vercel project env vars as well. Verify your sending
# domain in Resend; a subdomain such as updates.yourdomain.com is recommended.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="CommonLab <updates@yourdomain.com>"

# NextAuth / Auth.js
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe webhook endpoint:
# http://localhost:3000/api/payments/webhook

# Paystack
# Enables KES checkout with M-Pesa/mobile money, cards, bank transfer, webhooks,
# and optional educator subaccount splits.
PAYSTACK_SECRET_KEY=sk_test_...
# Paystack webhook endpoint:
# http://localhost:3000/api/payments/webhook
# Paystack signs webhooks with PAYSTACK_SECRET_KEY; there is no separate
# PAYSTACK_WEBHOOK_SECRET in this implementation.

# Admin (protects /api/admin/* routes)
ADMIN_SECRET=generate-a-strong-random-secret

# Semantic search / embeddings
# OPENAI_API_KEY enables real embeddings; without it, local deterministic
# embeddings keep development and tests working but are not production quality.
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_EMBEDDING_DIMENSIONS=1536
MONGODB_VECTOR_SEARCH_INDEX=course_content_vector

# Agent Commons SDK integration for course-agent creation/runs
AGENT_COMMONS_API_KEY=agc_...
AGENT_COMMONS_API_URL=https://api.agentcommons.io
AGENT_COMMONS_DEFAULT_MODEL_PROVIDER=openai
AGENT_COMMONS_DEFAULT_MODEL_ID=gpt-4o-mini
AGENT_COMMONS_GENERAL_AGENT_ID=agent_...
