# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/commons-courses

# App URLs
# NEXT_PUBLIC_BASE_URL is used for checkout success/cancel callbacks.
# EMAIL_BASE_URL is used for links in transactional emails. In production,
# set both values to the deployed courses domain.
NEXT_PUBLIC_BASE_URL=https://commonlab.agentcommons.io
EMAIL_BASE_URL=https://commonlab.agentcommons.io

# Resend / Email
# Add RESEND_API_KEY to Vercel project env vars as well. Verify your sending
# domain in Resend; a subdomain such as updates.yourdomain.com is recommended.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="CommonLab <updates@yourdomain.com>"
RESEND_REPLY_TO_EMAIL=hello@yourdomain.com

# NextAuth / Auth.js
# Auth.js v5 reads AUTH_SECRET. NEXTAUTH_SECRET is kept for compatibility.
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# Set this to the exact public origin you are testing from. Do not include a
# trailing slash. In Auth.js v5, AUTH_URL is also supported; keep both aligned
# in Vercel env vars if you use both.
NEXTAUTH_URL=https://commonlab.agentcommons.io
AUTH_URL=https://commonlab.agentcommons.io

# Google OAuth for fast learner signup/signin.
# Configure these exact callback URLs in Google Cloud OAuth:
# http://localhost:3000/api/auth/callback/google
# https://your-production-domain.com/api/auth/callback/google
# https://your-vercel-preview-domain.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe webhook endpoint:
# http://localhost:3000/api/payments/webhook

# Paystack
# Enables KES checkout with M-Pesa/mobile money, cards, bank transfer, webhooks,
# and optional educator subaccount splits.
PAYSTACK_SECRET_KEY=sk_test_...
# Paystack webhook endpoint:
# http://localhost:3000/api/payments/webhook
# Paystack signs webhooks with PAYSTACK_SECRET_KEY; there is no separate
# PAYSTACK_WEBHOOK_SECRET in this implementation.

# Admin (protects /api/admin/* routes)
ADMIN_SECRET=generate-a-strong-random-secret

# Course media storage
# Preferred production setup: upload course and skill assets to S3, then serve
# through CloudFront. COURSE_MEDIA_CDN_URL should be your CloudFront distribution
# URL, for example https://dxxxxx.cloudfront.net. If these are not set, uploads
# fall back to MongoDB-backed /api/media URLs for local development.
COURSE_MEDIA_S3_BUCKET=commonlab-course-media
COURSE_MEDIA_S3_REGION=us-east-1
COURSE_MEDIA_CDN_URL=https://dxxxxx.cloudfront.net
# Optional if you serve S3 objects directly instead of CloudFront.
COURSE_MEDIA_PUBLIC_URL=https://commonlab-course-media.s3.us-east-1.amazonaws.com

# Semantic search / embeddings
# OPENAI_API_KEY enables real embeddings; without it, local deterministic
# embeddings keep development and tests working but are not production quality.
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_EMBEDDING_DIMENSIONS=1536
MONGODB_VECTOR_SEARCH_INDEX=course_content_vector

# Agent Commons SDK integration for course-agent creation/runs
AGENT_COMMONS_API_KEY=agc_...
AGENT_COMMONS_API_URL=https://api.agentcommons.io
AGENT_COMMONS_DEFAULT_MODEL_PROVIDER=openai
AGENT_COMMONS_DEFAULT_MODEL_ID=gpt-4o-mini
AGENT_COMMONS_GENERAL_AGENT_ID=agent_...
