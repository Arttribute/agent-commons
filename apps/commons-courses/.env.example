# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/commons-courses

# App URLs
# NEXT_PUBLIC_BASE_URL is used for checkout success/cancel callbacks.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# NextAuth / Auth.js
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe webhook endpoint:
# http://localhost:3000/api/payments/webhook

# Paystack
# Enables KES checkout with M-Pesa/mobile money, cards, bank transfer, webhooks,
# and optional educator subaccount splits.
PAYSTACK_SECRET_KEY=sk_test_...
# Paystack webhook endpoint:
# http://localhost:3000/api/payments/webhook
# Paystack signs webhooks with PAYSTACK_SECRET_KEY; there is no separate
# PAYSTACK_WEBHOOK_SECRET in this implementation.

# Admin (protects /api/admin/* routes)
ADMIN_SECRET=generate-a-strong-random-secret
