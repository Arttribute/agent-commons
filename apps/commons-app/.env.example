AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

COMMONS_IDENTITY_ISSUER=http://localhost:3010/api/auth
COMMONS_IDENTITY_CLIENT_ID=
COMMONS_IDENTITY_CLIENT_SECRET=

# Server-side app proxy credential. This must be an OAuth client configured for
# client_credentials by `pnpm --filter commons-identity oauth:bootstrap`.
AGENT_COMMONS_SERVICE_CLIENT_ID=
AGENT_COMMONS_SERVICE_CLIENT_SECRET=

NEXT_PUBLIC_NEST_API_BASE_URL=https://api.agentcommons.io
COMMONS_IDENTITY_JWKS_URL=http://localhost:3010/api/auth/.well-known/jwks.json
COMMONS_IDENTITY_AUDIENCE=commons-platform

# Transitional only. Keep false once shared identity is deployed.
ALLOW_LEGACY_MANAGEMENT_AUTH=false
NEST_API_SECRET_KEY=

# Reserved sender for Agent Commons product notifications.
AGENT_COMMONS_UPDATES_FROM_EMAIL=Agent Commons <updates-agentcommons@agentcommons.io>

# Optional wallet infrastructure. Login does not depend on Privy.
NEXT_PUBLIC_PRIVY_APP_ID=

# Base Sepolia RPC used for wallet balance reads in the browser.
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=

# DEPRECATED: direct browser Supabase access is being removed (stats/logs move
# behind the API). Do not add new usages. Never expose more than the anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
