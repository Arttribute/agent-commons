COMMONS_CLI_CLIENT_ID=commons-cli
COMMONS_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003
COMMONS_GATEWAY_INTERNAL_SECRET=replace-with-a-long-random-secret

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
IDENTITY_ONBOARDING_FROM_EMAIL=Commons Accounts <onboarding@agentcommons.io>
